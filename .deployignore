# Used by the rsync deploy script — anything matching these patterns is
# never copied to the production server.
.git
.gitignore
node_modules
.next
out
dist
screenshots
screenshots-*
screenshot-*.png
screenshot-test.js
test-screenshots.js
test-screenshots.mjs
analyze-catalogue.js
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.DS_Store
*.log
npm-debug.log*
.idea
.vscode
.cursor
coverage
.nyc_output
.deployignore
