# ---------------------------------------------------------------------------
# Mediterra Fresh — environment variables
# Copy this file to `.env.local` (never commit it) and fill the values.
#
# IMPORTANT — this file configures *only* SYSTEM 1: the public website and
# its inbound contact form, on the brand domain mediterra-fresh.com.
#
# It does NOT configure cold outreach. Cold outreach lives on a SEPARATE
# domain (e.g. mediterra-fresh.co — to be registered) and is run from a
# SEPARATE tool (Instantly / Smartlead) — there is no env var for it here,
# and there shouldn't be.
# See docs/00-architecture-two-systems.md if this distinction is unclear.
# ---------------------------------------------------------------------------

# Site URL used by sitemap, OG tags, canonical links.
NEXT_PUBLIC_SITE_URL=https://mediterra-fresh.com

# ---- Inbound contact form transport (Resend, on the BRAND domain) --------
# 1. Create an account at https://resend.com
# 2. Add and verify mediterra-fresh.com (NOT the outreach domain) — Resend
#    will give you the DKIM, SPF (Return-Path) and DMARC records to add at
#    your DNS host.
# 3. Generate an API key (single-domain, send-only) and paste it below.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where the form posts arrive (your team's inbox on the brand domain).
CONTACT_EMAIL_TO=contact@mediterra-fresh.com

# Sender — must be on a verified domain in Resend (i.e. mediterra-fresh.com).
CONTACT_EMAIL_FROM="Mediterra Fresh <hello@mediterra-fresh.com>"
